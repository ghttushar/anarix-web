{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "anarix-mcp",
      "version": "0.1.0",
      "title": "Anarix MCP"
    },
    "tools": [
      {
        "name": "echo",
        "title": "Echo",
        "description": "Echo the input text back. Useful for verifying MCP connectivity.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1,
              "description": "Text to echo back."
            }
          },
          "required": [
            "text"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_applied_rules",
        "title": "List applied rules",
        "description": "List Anarix advertising automation rules, optionally filtered by status (running, paused, draft, ended).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "running",
                "paused",
                "draft",
                "ended"
              ],
              "description": "Optional status filter. Omit to return all rules."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_account_summary",
        "title": "Get account summary",
        "description": "Return a headline performance summary (spend, sales, ACoS, TACoS) for a marketplace over a lookback window.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "marketplace": {
              "type": "string",
              "enum": [
                "amazon-us",
                "amazon-uk",
                "walmart-us"
              ],
              "description": "Marketplace identifier."
            },
            "lookbackDays": {
              "type": "integer",
              "description": "Lookback window in days (e.g. 7, 30, 90). Clamped to 1-90 in code."
            }
          },
          "required": [
            "marketplace",
            "lookbackDays"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
